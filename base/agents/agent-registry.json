{
  "version": "2.0",
  "description": "Central registry mapping agents to their framework resources, team structure, and Agent Teams configuration",
  "teams": {
    "team-backend": {
      "name": "Backend Engineering Team",
      "description": "Server-side development: APIs, database, business logic, migrations",
      "leader": "backend-developer",
      "members": [
        "nestjs-specialist",
        "database-designer"
      ],
      "color": "green",
      "domain": [
        "api-endpoints",
        "database",
        "business-logic",
        "migrations",
        "backend-architecture"
      ]
    },
    "team-frontend": {
      "name": "Frontend & Mobile Team",
      "description": "Client-side development: React web, React Native mobile, UI components",
      "leader": "frontend-developer",
      "members": [
        "mobile-developer",
        "api-integration-agent"
      ],
      "color": "blue",
      "domain": [
        "ui-components",
        "routing",
        "state-management",
        "html-conversion",
        "mobile-features"
      ]
    },
    "team-quality": {
      "name": "Quality & Architecture Team",
      "description": "Code review, plan review, refactoring, error resolution, monitoring",
      "leader": "quality-lead",
      "members": [
        "reviewer",
        "refactorer",
        "auto-error-resolver",
        "agent-monitor",
        "gap-finder"
      ],
      "color": "purple",
      "domain": [
        "code-review",
        "plan-review",
        "refactoring",
        "error-resolution",
        "architecture-assessment",
        "monitoring"
      ]
    },
    "team-docs": {
      "name": "Documentation & Research Team",
      "description": "Documentation creation, PRD conversion, technical research",
      "leader": "documentation-architect",
      "members": [
        "web-research-specialist",
        "prd-converter"
      ],
      "color": "yellow",
      "domain": [
        "documentation",
        "prd-conversion",
        "research",
        "api-docs",
        "design-system-docs"
      ]
    }
  },
  "coordinator": {
    "agent": "project-coordinator",
    "description": "Top-level orchestrator for multi-team and multi-agent workflows",
    "manages": [
      "team-backend",
      "team-frontend",
      "team-quality",
      "team-docs"
    ],
    "crossTeamAgents": [
      "ticket-fixer"
    ]
  },
  "agentTypes": {
    "backend": {
      "description": "Backend development agents",
      "frameworks": [
        "nestjs"
      ],
      "color": "green",
      "defaultModel": "opus",
      "defaultPermissionMode": "acceptEdits",
      "defaultMaxTurns": 40,
      "role": "implementer"
    },
    "frontend": {
      "description": "Frontend web development agents",
      "frameworks": [
        "react"
      ],
      "color": "blue",
      "defaultModel": "opus",
      "defaultPermissionMode": "acceptEdits",
      "defaultMaxTurns": 40,
      "role": "implementer"
    },
    "mobile": {
      "description": "Mobile development agents",
      "frameworks": [
        "react-native"
      ],
      "color": "cyan",
      "defaultModel": "opus",
      "defaultPermissionMode": "acceptEdits",
      "defaultMaxTurns": 40,
      "role": "implementer"
    },
    "cross-stack": {
      "description": "Full-stack agents working across multiple frameworks",
      "frameworks": [
        "nestjs",
        "react"
      ],
      "color": "green",
      "defaultModel": "opus",
      "defaultPermissionMode": "acceptEdits",
      "defaultMaxTurns": 40,
      "role": "implementer"
    },
    "generic": {
      "description": "Framework-agnostic agents",
      "frameworks": [],
      "color": "blue",
      "defaultModel": "sonnet",
      "defaultPermissionMode": "default",
      "defaultMaxTurns": 25,
      "role": "specialist"
    }
  },
  "agents": {
    "project-coordinator": {
      "type": "cross-stack",
      "description": "Top-level orchestrator for parallel multi-agent collaboration and cross-team coordination",
      "frameworkOverrides": [
        "nestjs",
        "react"
      ],
      "permissionMode": "delegate",
      "maxTurns": 60,
      "role": "coordinator",
      "team": null,
      "canDelegate": [
        "backend-developer",
        "frontend-developer",
        "quality-lead",
        "documentation-architect",
        "ticket-fixer"
      ],
      "canBeCalledBy": [
        "user"
      ]
    },
    "backend-developer": {
      "type": "backend",
      "description": "NestJS backend implementation",
      "frameworkOverrides": null,
      "team": "team-backend",
      "role": "leader",
      "canDelegate": [
        "nestjs-specialist",
        "database-designer"
      ],
      "canBeCalledBy": [
        "project-coordinator",
        "ticket-fixer",
        "api-integration-agent",
        "prd-converter"
      ],
      "permissionMode": "acceptEdits",
      "maxTurns": 40,
      "mcpServers": [
        "mysql"
      ]
    },
    "nestjs-specialist": {
      "type": "backend",
      "description": "Advanced NestJS architecture and optimization",
      "frameworkOverrides": [
        "nestjs"
      ],
      "team": "team-backend",
      "role": "member",
      "canDelegate": [],
      "canBeCalledBy": [
        "backend-developer"
      ],
      "permissionMode": "acceptEdits",
      "maxTurns": 40,
      "mcpServers": [
        "mysql"
      ]
    },
    "database-designer": {
      "type": "backend",
      "description": "Database schema design and migrations",
      "frameworkOverrides": null,
      "team": "team-backend",
      "role": "member",
      "canDelegate": [],
      "canBeCalledBy": [
        "backend-developer",
        "project-coordinator",
        "ticket-fixer"
      ],
      "permissionMode": "acceptEdits",
      "maxTurns": 35,
      "mcpServers": [
        "mysql"
      ]
    },
    "frontend-developer": {
      "type": "frontend",
      "description": "React web development",
      "frameworkOverrides": null,
      "team": "team-frontend",
      "role": "leader",
      "canDelegate": [
        "mobile-developer",
        "api-integration-agent"
      ],
      "canBeCalledBy": [
        "project-coordinator",
        "ticket-fixer",
        "api-integration-agent",
        "prd-converter"
      ],
      "permissionMode": "acceptEdits",
      "maxTurns": 40,
      "mcpServers": [
        "playwright"
      ]
